from selenium import webdriver
from selenium.webdriver.chrome.options import Options
from bs4 import BeautifulSoup
import json
import time

def scrape_map_data():
    options = Options()
    options.add_argument("--headless") # Run in background
    driver = webdriver.Chrome(options=options)
    
    url = "https://result.election.gov.np/MapElectionResult2082.aspx"
    driver.get(url)
    time.sleep(5) # Allow map and AJAX to load

    soup = BeautifulSoup(driver.page_source, 'html.parser')
    constituencies = []

    # Target the map regions (this selector varies based on the SVG/Path structure)
    # Usually, each district/constituency is a <path> or <a> tag
    regions = soup.select('path[title], a[title]') 
    
    for area in regions:
        data = {
            "id": area.get('id', ''),
            "name": area.get('title', 'Unknown'),
            # The 'fill' or 'class' often indicates the winning party's color
            "party_color": area.get('fill', '#cccccc') 
        }
        constituencies.append(data)

    with open('map_results.json', 'w', encoding='utf-8') as f:
        json.dump(constituencies, f, ensure_ascii=False, indent=4)
    
    driver.quit()
    print(f"Scraped {len(constituencies)} areas.")

if __name__ == "__main__":
    scrape_map_data()
