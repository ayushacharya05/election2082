import requests
from bs4 import BeautifulSoup
import json

# URL of the 2082 Election Results
url = "https://result.election.gov.np/FPTPWLChartResult2082.aspx"

def scrape_election_data():
    response = requests.get(url)
    soup = BeautifulSoup(response.content, 'html.parser')
    
    # Targeting the main result table (usually found in a gridview or table tag)
    results = []
    table = soup.find('table') # Refine this selector based on actual page ID
    
    if table:
        rows = table.find_all('tr')[1:]  # Skip header
        for row in rows:
            cols = row.find_all('td')
            if len(cols) > 1:
                data = {
                    "candidate": cols[1].text.strip(),
                    "party": cols[2].text.strip(),
                    "votes": cols[3].text.strip(),
                    "status": cols[4].text.strip() if len(cols) > 4 else "Counting"
                }
                results.append(data)
                
    with open('election_data.json', 'w', encoding='utf-8') as f:
        json.dump(results, f, ensure_ascii=False, indent=4)
    print("Data scraped and saved to election_data.json")

# Note: You may need Selenium if the site uses JavaScript to load the table.
